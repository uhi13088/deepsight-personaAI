{
  "name": "deepsight-personaai",
  "version": "0.1.0",
  "private": true,
  "description": "AI 페르소나 기반 콘텐츠 추천 B2B SaaS 플랫폼",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:studio": "pnpm --filter engine-studio dev",
    "dev:console": "pnpm --filter developer-console dev",
    "build": "pnpm -r build",
    "build:studio": "pnpm --filter engine-studio build",
    "build:console": "pnpm --filter developer-console build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.11"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
