# ============================================
# DeepSight Engine Studio - Environment Variables Example
# ============================================
# Copy this file to .env.local and fill in the values

# --------------------------------------------
# Database (Required)
# --------------------------------------------
# Local development:
# DATABASE_URL="postgresql://postgres:password@localhost:5432/deepsight?schema=public"
# DIRECT_URL="postgresql://postgres:password@localhost:5432/deepsight?schema=public"

# Supabase (Production):
# - Pooler (port 6543): MUST include ?pgbouncer=true
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# - Direct (port 5432): For migrations
# DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"
DATABASE_URL="postgresql://postgres:password@localhost:5432/deepsight?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:5432/deepsight?schema=public"

# --------------------------------------------
# Authentication (Required)
# --------------------------------------------
NEXTAUTH_SECRET="your-secret-key-min-32-characters"
NEXTAUTH_URL="http://localhost:3000"

# OAuth Providers (Optional)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# --------------------------------------------
# Application URLs (Required)
# --------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="/api"

# --------------------------------------------
# AI/LLM APIs (Optional)
# --------------------------------------------
# OPENAI_API_KEY="sk-..."
# ANTHROPIC_API_KEY="sk-ant-..."

# --------------------------------------------
# External Services (Optional)
# --------------------------------------------
# ELASTICSEARCH_URL="http://localhost:9200"
# REDIS_URL="redis://localhost:6379"

# --------------------------------------------
# Feature Flags
# --------------------------------------------
FEATURE_DEMO_MODE="false"
FEATURE_OAUTH_ENABLED="false"
FEATURE_MFA_ENABLED="false"

# --------------------------------------------
# Development Settings
# --------------------------------------------
# Set to "true" to use mock data instead of real API calls
NEXT_PUBLIC_USE_MOCK_DATA="false"

# --------------------------------------------
# Rate Limiting (Optional)
# --------------------------------------------
# RATE_LIMIT_WINDOW_MS="60000"
# RATE_LIMIT_MAX_REQUESTS="100"

# --------------------------------------------
# Session (Optional)
# --------------------------------------------
# SESSION_MAX_AGE="28800"
# SESSION_UPDATE_AGE="3600"
