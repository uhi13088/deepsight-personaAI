{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "outputDirectory": ".next",
  "regions": ["icn1"],
  "headers": [],
  "crons": [
    {
      "path": "/api/cron/incubator-batch",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/persona-scheduler",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/content-auto-curation",
      "schedule": "0 3 * * *"
    }
  ]
}
