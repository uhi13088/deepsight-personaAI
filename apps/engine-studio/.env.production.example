# ============================================
# DeepSight Engine Studio - PRODUCTION Environment
# ============================================
# Vercel 배포 시 Vercel Dashboard > Settings > Environment Variables에서 설정
# 또는 vercel env pull로 로컬에 .env.local 생성

# --------------------------------------------
# Database (Required) - Supabase
# --------------------------------------------
# Supabase Dashboard > Settings > Database > Connection string
# Transaction mode (pgBouncer) - Serverless용
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session mode - Prisma 마이그레이션용
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres"

# --------------------------------------------
# Authentication (Required)
# --------------------------------------------
# 최소 32자 이상의 랜덤 문자열 (openssl rand -base64 32)
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Vercel 자동 설정됨, 또는 커스텀 도메인
NEXTAUTH_URL="https://engine.deepsight.ai"

# OAuth Providers (선택)
# GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="GOCSPX-xxx"
# GITHUB_CLIENT_ID="Iv1.xxx"
# GITHUB_CLIENT_SECRET="xxx"

# --------------------------------------------
# Application URLs (Required)
# --------------------------------------------
NEXT_PUBLIC_APP_URL="https://engine.deepsight.ai"
NEXT_PUBLIC_API_URL="/api"

# Developer Console URL
NEXT_PUBLIC_DEVELOPER_CONSOLE_URL="https://console.deepsight.ai"

# --------------------------------------------
# AI/LLM APIs (Required for AI features)
# --------------------------------------------
OPENAI_API_KEY="sk-proj-xxx"
# ANTHROPIC_API_KEY="sk-ant-xxx"

# --------------------------------------------
# Supabase (Required)
# --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# --------------------------------------------
# Redis/Upstash (Optional - 캐싱/Rate Limiting)
# --------------------------------------------
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="xxx"

# --------------------------------------------
# Feature Flags (Production)
# --------------------------------------------
FEATURE_DEMO_MODE="false"
FEATURE_OAUTH_ENABLED="true"
FEATURE_MFA_ENABLED="false"

# --------------------------------------------
# Production Settings
# --------------------------------------------
NEXT_PUBLIC_USE_MOCK_DATA="false"
NODE_ENV="production"

# --------------------------------------------
# Rate Limiting (Production)
# --------------------------------------------
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"

# --------------------------------------------
# Session (Production)
# --------------------------------------------
SESSION_MAX_AGE="28800"
SESSION_UPDATE_AGE="3600"

# --------------------------------------------
# Monitoring (Optional)
# --------------------------------------------
# SENTRY_DSN="https://xxx@o123.ingest.sentry.io/456"
# NEXT_PUBLIC_SENTRY_DSN="https://xxx@o123.ingest.sentry.io/456"
