// DeepSight AI Engine Studio - Database Schema
// v3.0 - 106D+ Multi-Layer Vector System

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// 인증 및 사용자 관리
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  image         String?
  role          UserRole  @default(ANALYST)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sessions      Session[]
  accounts      Account[]
  createdPersonas Persona[] @relation("CreatedBy")
  auditLogs     AuditLog[]
  abTests       ABTest[]  @relation("CreatedBy")
  createdVersions Version[] @relation("VersionCreatedBy")
  blogPosts     BlogPost[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token") @db.Text
  sessionState      String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

enum UserRole {
  ADMIN
  AI_ENGINEER
  CONTENT_MANAGER
  ANALYST
}

// ============================================
// 페르소나 관리
// ============================================

model Persona {
  id              String          @id @default(cuid())
  organizationId  String?
  visibility      PersonaVisibility @default(PRIVATE)
  sharedWithOrgs  String[]        @default([])

  // === 기본 정보 ===
  name            String
  role            PersonaRole
  expertise       String[]        @default([])
  description     String?
  profileImageUrl String?

  // === Layer 2: 캐릭터 속성 ===
  handle          String?         // SNS 핸들 (@yuna_feels)
  tagline         String?         // 한줄 자기소개
  birthDate       DateTime?       // 생년월일
  country         String?         @default("KR") // 국가 코드
  region          String?         // 지역
  warmth          Decimal?        @db.Decimal(3, 2) // 표현 온도 0.0~1.0
  expertiseLevel  ExpertiseLevel  @default(ENTHUSIAST)
  speechPatterns  String[]        @default([]) // 말버릇
  quirks          String[]        @default([]) // 특이 습관
  background      String?         @db.Text // 배경 스토리
  favoriteGenres  String[]        @default([]) // 선호 장르
  dislikedGenres  String[]        @default([]) // 비선호 장르
  viewingHabits   String?         // 시청 습관

  // === 활동성 속성 (PersonaWorld용) ===
  sociability     Decimal?        @db.Decimal(3, 2) // 사교성 0.0~1.0
  initiative      Decimal?        @db.Decimal(3, 2) // 주도성 0.0~1.0
  expressiveness  Decimal?        @db.Decimal(3, 2) // 표현력 0.0~1.0
  interactivity   Decimal?        @db.Decimal(3, 2) // 친화력 0.0~1.0
  postFrequency   PostFrequency   @default(MODERATE)
  timezone        String          @default("Asia/Seoul")
  activeHours     Int[]           @default([]) // 활동 시간대 [9, 12, 18, 22]
  peakHours       Int[]           @default([]) // 피크 시간대 [21, 22]

  // === 콘텐츠 생성 설정 (JSON) ===
  contentSettings Json?           // preferredPostTypes, contentStyle, reviewStyle, interactionStyle

  // === 관계 설정 (JSON) ===
  relationshipSettings Json?      // relationshipStyle, conflictStyle, collaborationStyle

  // === 프롬프트 템플릿 ===
  promptTemplate  String          @db.Text // 기본 프롬프트 (호환성 유지)
  promptVersion   String          @default("1.0")
  basePrompt      String?         @db.Text // 기본 페르소나 정의
  reviewPrompt    String?         @db.Text // 리뷰 생성용
  postPrompt      String?         @db.Text // 일반 포스트용
  commentPrompt   String?         @db.Text // 댓글 생성용
  interactionPrompt String?       @db.Text // 인터랙션용
  specialPrompts  Json?           // vsBattle, qna, debate, collab 등

  // === 품질 및 검증 ===
  status          PersonaStatus   @default(DRAFT)
  qualityScore    Decimal?        @db.Decimal(5, 2)
  validationScore Decimal?        @db.Decimal(3, 2)
  validationVersion Int?
  lastValidationDate DateTime?
  consistencyScore Decimal?       @db.Decimal(3, 2) // 일관성 점수

  // === 생성 소스 ===
  source          PersonaSource   @default(MANUAL)
  generationConfig Json?          // 자동 생성 시 사용된 설정
  parentPersonaId String?
  parentPersona   Persona?        @relation("PersonaParent", fields: [parentPersonaId], references: [id])
  childPersonas   Persona[]       @relation("PersonaParent")

  // === 샘플 콘텐츠 ===
  sampleContents  Json?           // 자동 생성된 샘플 콘텐츠

  // === v3.0 NEW: 3-Layer Paradox & Dynamics (JSON) ===
  paradoxConfig       Json?           // ParadoxConfig type
  dynamicsConfig      Json?           // DynamicsConfig type

  // === v3.0 NEW: Qualitative Dimensions (JSON) ===
  backstory           Json?           // BackstoryDimension
  pressureContext     Json?           // PressureContext
  voiceProfile        Json?           // VoiceProfile
  zeitgeist           Json?           // ZeitgeistProfile

  // === v3.0 NEW: Interaction Rules (JSON) ===
  interactionRules    Json?           // InteractionRules (Init/Override/Adapt/Express)

  // === v4.0 NEW: Instruction Layer ===
  voiceSpec           Json?           // VoiceSpec (profile + styleParams + guardrails + adaptations + consistency)
  factbook            Json?           // Factbook (immutableFacts + mutableContext + integrityHash)
  triggerMap          Json?           // TriggerRuleDSL[] (structured rule engine)

  // === v3.0 NEW: Archetype & Scores ===
  archetypeId         String?
  paradoxScore        Decimal?        @db.Decimal(4, 3) // 0.000~1.000
  dimensionalityScore Decimal?        @db.Decimal(4, 3) // 0.000~1.000
  engineVersion       String?         @default("4.0")

  // === 타임스탬프 ===
  createdById     String
  createdBy       User            @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  activatedAt     DateTime?
  archivedAt      DateTime?

  // Relations
  vectors         PersonaVector[]
  layerVectors    PersonaLayerVector[]
  matchingLogs    MatchingLog[]
  feedbacks       Feedback[]
  testResults     PersonaTestResult[]
  interactionSessions InteractionSession[]
  posts           PersonaPost[]
  givenLikes      PersonaPostLike[] @relation("PersonaLikes")
  givenComments   PersonaComment[] @relation("PersonaComments")
  givenReposts    PersonaRepost[] @relation("PersonaReposts")
  following       PersonaFollow[] @relation("PersonaFollowing")
  followers       PersonaFollow[] @relation("PersonaFollowers")

  // PersonaWorld v3
  personaState        PersonaState?
  relationshipsAsA    PersonaRelationship[] @relation("RelationshipA")
  relationshipsAsB    PersonaRelationship[] @relation("RelationshipB")
  consumptionLogs     ConsumptionLog[]
  generationRequests  PersonaGenerationRequest[]

  @@map("personas")
}

model PersonaVector {
  id        String   @id @default(cuid())
  personaId String
  persona   Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  version   Int      @default(1)

  // 6D Vector (legacy — backward compat)
  depth     Decimal  @db.Decimal(3, 2)  // 분석 깊이: 직관적(0.0) ↔ 심층적(1.0)
  lens      Decimal  @db.Decimal(3, 2)  // 판단 렌즈: 감성적(0.0) ↔ 논리적(1.0)
  stance    Decimal  @db.Decimal(3, 2)  // 평가 태도: 수용적(0.0) ↔ 비판적(1.0)
  scope     Decimal  @db.Decimal(3, 2)  // 관심 범위: 핵심만(0.0) ↔ 디테일(1.0)
  taste     Decimal  @db.Decimal(3, 2)  // 취향 성향: 클래식(0.0) ↔ 실험적(1.0)
  purpose   Decimal  @db.Decimal(3, 2)  // 소비 목적: 오락(0.0) ↔ 의미추구(1.0)

  createdAt DateTime @default(now())

  @@map("persona_vectors")
}

// ============================================
// v3.0 NEW: 3-Layer 벡터 저장 (106D+)
// ============================================

model PersonaLayerVector {
  id        String    @id @default(cuid())
  personaId String
  persona   Persona   @relation(fields: [personaId], references: [id], onDelete: Cascade)

  layerType LayerType
  version   Int       @default(1)

  // Decimal(4,3) = 0.000~1.000 range
  // SOCIAL(L1): dim1~dim7, TEMPERAMENT(L2): dim1~dim5, NARRATIVE(L3): dim1~dim4
  dim1      Decimal?  @db.Decimal(4, 3)
  dim2      Decimal?  @db.Decimal(4, 3)
  dim3      Decimal?  @db.Decimal(4, 3)
  dim4      Decimal?  @db.Decimal(4, 3)
  dim5      Decimal?  @db.Decimal(4, 3)
  dim6      Decimal?  @db.Decimal(4, 3)
  dim7      Decimal?  @db.Decimal(4, 3)

  createdAt DateTime  @default(now())

  @@unique([personaId, layerType, version])
  @@index([personaId])
  @@index([layerType])
  @@map("persona_layer_vectors")
}

enum LayerType {
  SOCIAL        // Layer 1: 7D (depth, lens, stance, scope, taste, purpose, sociability)
  TEMPERAMENT   // Layer 2: 5D (openness, conscientiousness, extraversion, agreeableness, neuroticism)
  NARRATIVE     // Layer 3: 4D (lack, moralCompass, volatility, growthArc)
}

enum PersonaVisibility {
  GLOBAL
  PRIVATE
  SHARED
}

enum PersonaRole {
  REVIEWER
  CURATOR
  EDUCATOR
  COMPANION
  ANALYST
}

enum PersonaStatus {
  DRAFT
  REVIEW
  ACTIVE
  STANDARD
  LEGACY
  DEPRECATED
  PAUSED
  ARCHIVED
}

enum PersonaSource {
  MANUAL
  INCUBATOR
  MUTATION
  AUTO_GENERATED  // 자동 생성
  USER_REQUEST    // PersonaWorld 사용자 요청
}

enum ExpertiseLevel {
  CASUAL      // 가벼운 시청자
  ENTHUSIAST  // 영화 애호가
  EXPERT      // 전문가
  CRITIC      // 평론가
}

enum PostFrequency {
  RARE        // 주 1회 미만
  OCCASIONAL  // 주 1-2회
  MODERATE    // 주 3-4회
  ACTIVE      // 주 5-6회
  HYPERACTIVE // 매일+
}

// ============================================
// 사용자 벡터 및 아키타입
// ============================================

model UserVector {
  id              String   @id @default(cuid())
  userId          String   @unique
  onboardingLevel OnboardingLevel @default(LIGHT)

  // 6D Vector (L1 기본)
  depth           Decimal  @db.Decimal(3, 2)
  lens            Decimal  @db.Decimal(3, 2)
  stance          Decimal  @db.Decimal(3, 2)
  scope           Decimal  @db.Decimal(3, 2)
  taste           Decimal  @db.Decimal(3, 2)
  purpose         Decimal  @db.Decimal(3, 2)

  // v3.0 NEW: L1 7th dimension
  sociability     Decimal? @db.Decimal(3, 2)

  // v3.0 NEW: L2 OCEAN (optional — SNS 연동 시 채워짐)
  openness        Decimal? @db.Decimal(3, 2)
  conscientiousness Decimal? @db.Decimal(3, 2)
  extraversion    Decimal? @db.Decimal(3, 2)
  agreeableness   Decimal? @db.Decimal(3, 2)
  neuroticism     Decimal? @db.Decimal(3, 2)

  hasOceanProfile Boolean  @default(false)

  archetype       String?
  confidenceScores Json?

  updatedAt       DateTime @updatedAt

  @@map("user_vectors")
}

model Archetype {
  id              String   @id @default(cuid())
  name            String   @unique
  nameKo          String?  @map("name_ko")
  description     String?

  // Vector ranges (min-max for each dimension)
  depthMin        Decimal  @db.Decimal(3, 2)
  depthMax        Decimal  @db.Decimal(3, 2)
  lensMin         Decimal  @db.Decimal(3, 2)
  lensMax         Decimal  @db.Decimal(3, 2)
  stanceMin       Decimal  @db.Decimal(3, 2)
  stanceMax       Decimal  @db.Decimal(3, 2)
  scopeMin        Decimal  @db.Decimal(3, 2)
  scopeMax        Decimal  @db.Decimal(3, 2)
  tasteMin        Decimal  @db.Decimal(3, 2)
  tasteMax        Decimal  @db.Decimal(3, 2)
  purposeMin      Decimal  @db.Decimal(3, 2)
  purposeMax      Decimal  @db.Decimal(3, 2)

  referenceVector Json?    @map("reference_vector") // Record<SocialDimension, number>
  thresholdConfig Json?    @map("threshold_config") // ArchetypeThreshold[]
  isBuiltin       Boolean  @default(false) @map("is_builtin")

  recommendedPersonaIds String[] @default([])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("archetypes")
}

enum OnboardingLevel {
  LIGHT   // Quick Mode: 12 questions, 2min
  MEDIUM  // Standard Mode: 30 questions, 5min
  DEEP    // Deep Mode: 60 questions, 15min
}

// ============================================
// 매칭 알고리즘
// ============================================

model MatchingAlgorithm {
  id              String   @id @default(cuid())
  name            String
  version         String
  algorithmType   AlgorithmType
  parameters      Json?
  weights         Json?
  contextRules    Json?
  status          AlgorithmStatus @default(DRAFT)
  deployedEnv     String[] @default([])
  performanceMetrics Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  versions        AlgorithmVersion[]
  matchingLogs    MatchingLog[]
  abTestsControl  ABTest[] @relation("ControlAlgorithm")
  abTestsTest     ABTest[] @relation("TestAlgorithm")

  @@map("matching_algorithms")
}

model AlgorithmVersion {
  id              String   @id @default(cuid())
  algorithmId     String
  algorithm       MatchingAlgorithm @relation(fields: [algorithmId], references: [id], onDelete: Cascade)
  version         String
  parentVersion   String?
  changeType      ChangeType
  changeSummary   String
  changeDetails   Json?
  parametersSnapshot Json?
  weightsSnapshot Json?
  contextRulesSnapshot Json?
  deployedTo      String[] @default([])

  createdAt       DateTime @default(now())

  @@map("algorithm_versions")
}

enum AlgorithmType {
  COSINE
  WEIGHTED
  CONTEXT
  HYBRID
}

enum AlgorithmStatus {
  DRAFT
  TESTING
  ACTIVE
  DEPRECATED
}

enum ChangeType {
  MAJOR
  MINOR
  PATCH
  ROLLBACK
}

// ============================================
// 매칭 로그
// ============================================

model MatchingLog {
  id              String   @id @default(cuid())
  requestId       String   @unique @default(cuid())
  userId          String
  algorithmId     String?
  algorithm       MatchingAlgorithm? @relation(fields: [algorithmId], references: [id])
  algorithmVersion String?
  context         Json?
  matchedPersonas Json?    // [{persona_id, score, rank}]
  selectedPersonaId String?
  selectedPersona Persona? @relation(fields: [selectedPersonaId], references: [id])
  feedback        FeedbackType?
  responseTimeMs  Int?

  createdAt       DateTime @default(now())
  feedbackAt      DateTime?

  @@map("matching_logs")
}

model Feedback {
  id              String   @id @default(cuid())
  userId          String
  personaId       String
  persona         Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  feedbackType    FeedbackType
  contentId       String?
  comment         String?

  createdAt       DateTime @default(now())

  @@map("feedbacks")
}

enum FeedbackType {
  LIKE
  DISLIKE
  NONE
}

// ============================================
// A/B 테스트
// ============================================

model ABTest {
  id              String   @id @default(cuid())
  name            String
  description     String?
  testType        ABTestType
  status          ABTestStatus @default(DRAFT)

  controlConfig   Json
  controlAlgorithmId String?
  controlAlgorithm MatchingAlgorithm? @relation("ControlAlgorithm", fields: [controlAlgorithmId], references: [id])

  testConfig      Json
  testAlgorithmId String?
  testAlgorithm   MatchingAlgorithm? @relation("TestAlgorithm", fields: [testAlgorithmId], references: [id])

  trafficSplit    Decimal  @db.Decimal(3, 2) @default(0.5)
  startDate       DateTime?
  endDate         DateTime?
  results         Json?

  createdById     String
  createdBy       User     @relation("CreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("ab_tests")
}

enum ABTestType {
  ALGORITHM
  PERSONA
  PARAMETER
  WEIGHT
  DIMENSION
}

enum ABTestStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

// ============================================
// 심리 프로파일링 템플릿
// ============================================

model PsychProfileTemplate {
  id              String   @id @default(cuid())
  name            String
  onboardingLevel OnboardingLevel
  questionOrder   Int
  questionText    String
  questionType    QuestionType
  options         Json?
  targetDimensions String[] @default([])
  weightFormula   Json?
  isRequired      Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  surveyQuestions SurveyQuestion[]

  @@map("psych_profile_templates")
}

enum QuestionType {
  SLIDER
  MULTIPLE_CHOICE
  RANKING
  TEXT
  IMAGE
}

// ============================================
// 설문 시스템
// ============================================

model Survey {
  id              String          @id @default(cuid())
  title           String
  description     String?
  onboardingLevel OnboardingLevel
  isActive        Boolean         @default(true)

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  questions       SurveyQuestion[]
  responses       SurveyResponse[]

  @@map("surveys")
}

model SurveyQuestion {
  id              String               @id @default(cuid())
  surveyId        String
  survey          Survey               @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  templateId      String
  template        PsychProfileTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  questionOrder   Int
  isRequired      Boolean              @default(true)

  @@unique([surveyId, templateId])
  @@map("survey_questions")
}

model SurveyResponse {
  id              String         @id @default(cuid())
  surveyId        String
  survey          Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  userId          String
  answers         SurveyAnswer[]
  computedVector  Json?
  completedAt     DateTime?

  createdAt       DateTime       @default(now())

  @@unique([surveyId, userId])
  @@map("survey_responses")
}

model SurveyAnswer {
  id              String         @id @default(cuid())
  responseId      String
  response        SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId      String
  value           Json

  createdAt       DateTime       @default(now())

  @@unique([responseId, questionId])
  @@map("survey_answers")
}

// ============================================
// 골든 샘플 (테스트용)
// ============================================

model GoldenSample {
  id              String   @id @default(cuid())
  contentTitle    String
  contentType     String?
  genre           String?
  description     String?
  testQuestion    String
  expectedReactions Json?
  difficultyLevel DifficultyLevel @default(MEDIUM)
  validationDimensions String[] @default([])
  version         Int      @default(1)
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("golden_samples")
}

enum DifficultyLevel {
  EASY
  MEDIUM
  HARD
}

// ============================================
// 인큐베이터 로그
// ============================================

model IncubatorLog {
  id              String   @id @default(cuid())
  batchId         String
  batchDate       DateTime @db.Date
  personaConfig   Json?
  generatedVector Json?
  generatedPrompt String?  @db.Text
  testSampleIds   String[] @default([])
  testResults     Json?
  consistencyScore Decimal? @db.Decimal(3, 2)
  vectorAlignmentScore Decimal? @db.Decimal(3, 2)
  toneMatchScore  Decimal? @db.Decimal(3, 2)
  reasoningQualityScore Decimal? @db.Decimal(3, 2)
  status          IncubatorStatus @default(PENDING)

  createdAt       DateTime @default(now())

  @@map("incubator_logs")
}

enum IncubatorStatus {
  PENDING
  PASSED
  FAILED
  APPROVED
  REJECTED
}

// ============================================
// 리뷰 스타일 (v3.0)
// ============================================

model ReviewStyle {
  id              String   @id // S01~S32
  name            String
  description     String?
  depthLevel      String   // HIGH/LOW
  lensLevel       String   // 감성/논리
  stanceLevel     String   // 수용/비판
  scopeLevel      String   // 핵심/디테일
  tasteLevel      String   // 클래식/실험
  systemPrompt    String   @db.Text

  createdAt       DateTime @default(now())

  // Relations
  contentReviews  StyleContentReview[]

  @@map("review_styles")
}

model StyleContentReview {
  id              String   @id @default(cuid())
  styleId         String
  style           ReviewStyle @relation(fields: [styleId], references: [id], onDelete: Cascade)
  contentId       String
  contentType     String?
  rating          Decimal? @db.Decimal(3, 1)
  reviewText      String   @db.Text
  reviewSummary   String?
  keywords        String[] @default([])
  generationTrigger String?

  generatedAt     DateTime @default(now())

  @@unique([styleId, contentId])
  @@map("style_content_reviews")
}

model StyleReviewLog {
  id              String   @id @default(cuid())
  userId          String
  personaId       String
  styleId         String
  contentId       String
  styleCacheHit   Boolean
  transformType   String?  // TEMPLATE, LLM, NULL
  styleGenerationCost Decimal? @db.Decimal(10, 6)
  transformCost   Decimal? @db.Decimal(10, 6)

  createdAt       DateTime @default(now())

  @@map("style_review_logs")
}

// ============================================
// 페르소나 테스트 결과
// ============================================

model PersonaTestResult {
  id              String   @id @default(cuid())
  personaId       String
  persona         Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)
  testType        String   // SINGLE, BATCH, GOLDEN
  sampleContent   Json?
  response        String?  @db.Text
  consistencyScore Decimal? @db.Decimal(3, 2)
  toneMatchScore  Decimal? @db.Decimal(3, 2)
  reasoningScore  Decimal? @db.Decimal(3, 2)
  overallScore    Decimal? @db.Decimal(3, 2)

  createdAt       DateTime @default(now())

  @@map("persona_test_results")
}

// ============================================
// API 엔드포인트 관리
// ============================================

model ApiEndpoint {
  id              String         @id @default(cuid())
  path            String
  method          HttpMethod
  name            String
  description     String?
  version         String         @default("v1")
  status          EndpointStatus @default(ACTIVE)
  category        String         @default("general")
  scope           String         @default("external") // internal | external
  requiresAuth    Boolean        @default(true)
  rateLimit       Int            @default(100)  // req/min
  timeout         Int            @default(30000) // ms
  rateLimitConfig Json?          // { requestsPerMinute, burstLimit, windowSizeMs }
  healthCheckConfig Json?        // { enabled, intervalMs, timeoutMs, unhealthyThreshold }
  tags            String[]       @default([])

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([path, method])
  @@map("api_endpoints")
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}

enum EndpointStatus {
  ACTIVE
  DEPRECATED
  DISABLED
}

// ============================================
// 시스템 설정
// ============================================

model SystemConfig {
  id              String   @id @default(cuid())
  category        String   // MODEL, SAFETY, API
  key             String
  value           Json
  description     String?

  updatedAt       DateTime @updatedAt

  @@unique([category, key])
  @@map("system_configs")
}

model SafetyFilter {
  id              String   @id @default(cuid())
  name            String
  filterType      FilterType
  pattern         String   // Regex pattern
  isActive        Boolean  @default(true)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("safety_filters")
}

enum FilterType {
  PROFANITY
  HATE_SPEECH
  POLITICAL
  RELIGIOUS
  CUSTOM
}

// ============================================
// 배포 관리
// ============================================

model Deployment {
  id              String   @id @default(cuid())
  targetType      DeploymentTarget
  targetId        String
  environment     DeploymentEnv
  status          DeploymentStatus @default(PENDING)
  version         String?
  notes           String?
  deployedById    String

  createdAt       DateTime @default(now())
  completedAt     DateTime?

  @@map("deployments")
}

enum DeploymentTarget {
  PERSONA
  ALGORITHM
  CONFIG
}

enum DeploymentEnv {
  DEV
  STG
  PROD
}

enum DeploymentStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
  ROLLED_BACK
}

// ============================================
// 장애 관리
// ============================================

model Incident {
  id              String   @id @default(cuid())
  title           String
  description     String   @db.Text
  severity        IncidentSeverity
  status          IncidentStatus @default(REPORTED)
  affectedSystems String[] @default([])
  resolution      String?  @db.Text
  reportedById    String

  createdAt       DateTime @default(now())
  resolvedAt      DateTime?
  updatedAt       DateTime @updatedAt

  // Relations
  timeline        IncidentTimeline[]
  postMortems     PostMortem[]

  @@map("incidents")
}

model IncidentTimeline {
  id              String   @id @default(cuid())
  incidentId      String
  incident        Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  action          String
  description     String
  performedById   String

  createdAt       DateTime @default(now())

  @@map("incident_timelines")
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  REPORTED
  INVESTIGATING
  IDENTIFIED
  FIXING
  RESOLVED
  CLOSED
}

// ============================================
// 감사 로그
// ============================================

model AuditLog {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  action          String
  targetType      String
  targetId        String?
  details         Json?
  ipAddress       String?
  userAgent       String?

  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// 시스템 모니터링
// ============================================

model SystemMetric {
  id              String   @id @default(cuid())
  metricType      String   // CPU, MEMORY, DISK, API_LATENCY, ERROR_RATE
  value           Decimal  @db.Decimal(10, 4)
  unit            String
  tags            Json?

  recordedAt      DateTime @default(now())

  @@index([metricType, recordedAt])
  @@map("system_metrics")
}

// ============================================
// 백업 기록
// ============================================

model BackupRecord {
  id              String   @id @default(cuid())
  backupType      BackupType
  status          BackupStatus @default(IN_PROGRESS)
  size            BigInt?
  location        String?
  notes           String?

  startedAt       DateTime @default(now())
  completedAt     DateTime?

  @@map("backup_records")
}

enum BackupType {
  FULL
  INCREMENTAL
  DIFFERENTIAL
}

enum BackupStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

// ============================================
// 버전 관리
// ============================================

model Version {
  id              String   @id @default(cuid())
  tag             String   @unique
  name            String
  description     String   @default("")
  commitHash      String
  branch          String   @default("main")
  environment     String?  // development, staging, production
  status          VersionStatus @default(ACTIVE)
  addedCount      Int      @default(0)
  modifiedCount   Int      @default(0)
  deletedCount    Int      @default(0)
  components      String[] @default([])

  createdById     String
  createdByUser   User     @relation("VersionCreatedBy", fields: [createdById], references: [id])
  createdAt       DateTime @default(now())

  @@map("versions")
}

model Commit {
  id              String   @id @default(cuid())
  hash            String   @unique
  message         String
  author          String
  authorEmail     String
  branch          String   @default("main")
  filesChanged    Int      @default(0)

  createdAt       DateTime @default(now())

  @@map("commits")
}

model Branch {
  id              String   @id @default(cuid())
  name            String   @unique
  lastCommitMessage String @default("")
  lastCommitDate  DateTime @default(now())
  lastCommitAuthor String  @default("")
  isProtected     Boolean  @default(false)
  isDefault       Boolean  @default(false)
  aheadCount      Int      @default(0)
  behindCount     Int      @default(0)

  createdAt       DateTime @default(now())

  @@map("branches")
}

enum VersionStatus {
  ACTIVE
  DEPRECATED
  ARCHIVED
}

// ============================================
// PersonaWorld - SNS 시스템
// ============================================

model PersonaPost {
  id          String          @id @default(cuid())
  personaId   String
  persona     Persona         @relation(fields: [personaId], references: [id], onDelete: Cascade)

  type        PersonaPostType
  content     String          @db.Text
  contentId   String?         // 리뷰 대상 콘텐츠 ID (있으면)
  metadata    Json?           // 포스트 타입별 추가 데이터 (VS_BATTLE 옵션, Q&A 질문 등)

  // 스레드 지원
  parentId    String?
  parent      PersonaPost?    @relation("PostThread", fields: [parentId], references: [id])
  children    PersonaPost[]   @relation("PostThread")

  // 트리거 정보
  trigger     ActivityTrigger @default(SCHEDULED)

  // 통계 (비정규화)
  likeCount     Int           @default(0)
  commentCount  Int           @default(0)
  repostCount   Int           @default(0)

  isHidden    Boolean         @default(false) // 관리자 숨김
  hiddenAt    DateTime?
  hiddenBy    String?         // 숨긴 관리자 ID

  // v4.0: Poignancy Score (감정 가중 기억 검색)
  poignancyScore Decimal?     @db.Decimal(4, 3)  // 0.000~1.000

  // v4.0: Data Provenance (출처 추적)
  postSource  PostSource?     @default(AUTONOMOUS)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  likes       PersonaPostLike[]
  comments    PersonaComment[]
  reposts     PersonaRepost[]

  @@index([personaId, createdAt])
  @@index([type, createdAt])
  @@map("persona_posts")
}

model PersonaPostLike {
  id        String      @id @default(cuid())
  postId    String
  post      PersonaPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  // 페르소나 또는 유저 (둘 중 하나만)
  personaId String?
  persona   Persona?    @relation("PersonaLikes", fields: [personaId], references: [id], onDelete: Cascade)
  userId    String?
  user      PersonaWorldUser? @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime    @default(now())

  @@unique([postId, personaId])
  @@unique([postId, userId])
  @@map("persona_post_likes")
}

model PersonaComment {
  id        String      @id @default(cuid())
  postId    String
  post      PersonaPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  // 페르소나 또는 유저 (둘 중 하나만)
  personaId String?
  persona   Persona?    @relation("PersonaComments", fields: [personaId], references: [id], onDelete: Cascade)
  userId    String?
  user      PersonaWorldUser? @relation(fields: [userId], references: [id], onDelete: Cascade)

  content   String      @db.Text
  tone      String?     // 11종 댓글 톤 (v4: paradox_response~supportive)

  // 답글 지원
  parentId  String?
  parent    PersonaComment? @relation("CommentReply", fields: [parentId], references: [id])
  replies   PersonaComment[] @relation("CommentReply")

  isHidden  Boolean     @default(false)
  hiddenAt  DateTime?
  hiddenBy  String?

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([postId, createdAt])
  @@map("persona_comments")
}

model PersonaRepost {
  id            String      @id @default(cuid())
  originalPostId String
  originalPost  PersonaPost @relation(fields: [originalPostId], references: [id], onDelete: Cascade)

  // 페르소나 또는 유저 (둘 중 하나만)
  personaId     String?
  persona       Persona?    @relation("PersonaReposts", fields: [personaId], references: [id], onDelete: Cascade)
  userId        String?
  user          PersonaWorldUser? @relation(fields: [userId], references: [id], onDelete: Cascade)

  comment       String?     @db.Text // 리포스트 코멘트

  createdAt     DateTime    @default(now())

  @@unique([originalPostId, personaId])
  @@unique([originalPostId, userId])
  @@map("persona_reposts")
}

model PersonaFollow {
  id                  String    @id @default(cuid())

  // 팔로우 하는 주체 (페르소나 또는 유저)
  followerPersonaId   String?
  followerPersona     Persona?  @relation("PersonaFollowing", fields: [followerPersonaId], references: [id], onDelete: Cascade)
  followerUserId      String?
  followerUser        PersonaWorldUser? @relation("UserFollowing", fields: [followerUserId], references: [id], onDelete: Cascade)

  // 팔로우 대상 (페르소나만)
  followingPersonaId  String
  followingPersona    Persona   @relation("PersonaFollowers", fields: [followingPersonaId], references: [id], onDelete: Cascade)

  createdAt           DateTime  @default(now())

  @@unique([followerPersonaId, followingPersonaId])
  @@unique([followerUserId, followingPersonaId])
  @@map("persona_follows")
}

enum PersonaPostType {
  // 기본 타입
  REVIEW
  THOUGHT
  RECOMMENDATION
  REACTION
  QUESTION
  LIST
  THREAD
  // 특별 콘텐츠 타입
  VS_BATTLE
  QNA
  CURATION
  DEBATE
  MEME
  COLLAB
  TRIVIA
  PREDICTION
  ANNIVERSARY
  BEHIND_STORY
}

enum ActivityTrigger {
  SCHEDULED       // 정기 스케줄
  MANUAL          // 관리자 수동 실행
  CONTENT_RELEASE // 새 콘텐츠 출시
  SOCIAL_EVENT    // 다른 페르소나 활동
  USER_INTERACTION // 유저 인터랙션
  TRENDING        // 트렌딩 토픽
  AUTONOMOUS      // 자율 활동
}

// ============================================
// PersonaWorld - 유저 프로필
// ============================================

model PersonaWorldUser {
  id              String          @id @default(cuid())
  email           String          @unique
  name            String?
  profileImageUrl String?

  // === 6D 벡터 (유저의 취향) ===
  depth           Decimal?        @db.Decimal(3, 2)
  lens            Decimal?        @db.Decimal(3, 2)
  stance          Decimal?        @db.Decimal(3, 2)
  scope           Decimal?        @db.Decimal(3, 2)
  taste           Decimal?        @db.Decimal(3, 2)
  purpose         Decimal?        @db.Decimal(3, 2)

  // === v3: L2 OCEAN (선택 수집) ===
  openness          Decimal?        @db.Decimal(3, 2)
  conscientiousness Decimal?        @db.Decimal(3, 2)
  extraversion      Decimal?        @db.Decimal(3, 2)
  agreeableness     Decimal?        @db.Decimal(3, 2)
  neuroticism       Decimal?        @db.Decimal(3, 2)
  hasOceanProfile   Boolean         @default(false)

  // === v3: 프로필 품질 레벨 ===
  profileLevel    String          @default("BASIC") @map("profile_level") // BASIC | STANDARD | ADVANCED | PREMIUM

  // === 프로필 품질 ===
  profileQuality  ProfileQuality  @default(BASIC)
  confidenceScore Decimal?        @db.Decimal(3, 2)

  // === 데이터 소스 기록 (JSON) ===
  dataSources     Json?           // coldStart, sns, activity 정보

  // === SNS 확장 데이터 (JSON) ===
  snsExtendedData Json?           // 플랫폼별 확장 데이터

  // === 선호도 ===
  preferences     Json?           // favoriteGenres, warmthPreference 등

  isActive        Boolean         @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  likes           PersonaPostLike[]
  comments        PersonaComment[]
  reposts         PersonaRepost[]
  following       PersonaFollow[] @relation("UserFollowing")
  bookmarks       PersonaPostBookmark[]
  notifications   PWNotification[]
  surveyResponses PWUserSurveyResponse[]
  personaRequests PersonaGenerationRequest[]

  @@map("persona_world_users")
}

model PersonaPostBookmark {
  id        String           @id @default(cuid())
  userId    String
  user      PersonaWorldUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    String

  createdAt DateTime         @default(now())

  @@unique([userId, postId])
  @@map("persona_post_bookmarks")
}

model PWUserSurveyResponse {
  id              String           @id @default(cuid())
  userId          String
  user            PersonaWorldUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  surveyLevel     OnboardingLevel
  answers         Json             // 질문별 답변
  computedVector  Json?            // 계산된 6D 벡터
  completedAt     DateTime?

  createdAt       DateTime         @default(now())

  @@unique([userId, surveyLevel])
  @@map("pw_user_survey_responses")
}

model SNSConnection {
  id              String           @id @default(cuid())
  userId          String
  platform        SNSPlatform
  accessToken     String?          @db.Text
  refreshToken    String?          @db.Text
  expiresAt       DateTime?
  profileData     Json?            // 플랫폼별 프로필 데이터
  extractedData   Json?            // 추출된 데이터 (6D 벡터 포함)
  lastSyncAt      DateTime?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([userId, platform])
  @@map("sns_connections")
}

enum ProfileQuality {
  BASIC     // Cold Start LIGHT
  STANDARD  // Cold Start MEDIUM 또는 SNS 1개
  ADVANCED  // Cold Start DEEP 또는 SNS 2개+
  PREMIUM   // Cold Start + SNS 복합
}

enum SNSPlatform {
  NETFLIX
  YOUTUBE
  INSTAGRAM
  SPOTIFY
  LETTERBOXD
  TWITTER
  TIKTOK
}

// ============================================
// PersonaWorld - 알림
// ============================================

model PWNotification {
  id          String   @id @default(cuid())
  userId      String
  user        PersonaWorldUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String   // like, comment, follow, mention, recommendation, new_post, system
  message     String
  personaId   String?  // 관련 페르소나 (있을 때)
  personaName String?
  postId      String?  // 관련 포스트 (있을 때)
  commentId   String?  // 관련 댓글 (있을 때)

  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("pw_notifications")
}

// ============================================
// PersonaWorld - 신고 및 모더레이션
// ============================================

model PersonaWorldReport {
  id              String           @id @default(cuid())
  reporterUserId  String
  targetType      ReportTargetType
  targetId        String           // postId 또는 commentId
  reason          ReportReason
  description     String?          @db.Text
  status          ReportStatus     @default(PENDING)
  resolvedAt      DateTime?
  resolvedBy      String?
  resolution      String?          @db.Text

  createdAt       DateTime         @default(now())

  @@index([status, createdAt])
  @@map("persona_world_reports")
}

enum ReportTargetType {
  POST
  COMMENT
}

enum ReportReason {
  SPAM
  INAPPROPRIATE
  HARASSMENT
  MISINFORMATION
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

// ============================================
// PersonaWorld - 활동 로그
// ============================================

model PersonaActivityLog {
  id              String           @id @default(cuid())
  personaId       String
  activityType    PersonaActivityType
  targetId        String?          // postId, commentId, followId 등
  metadata        Json?            // 활동 상세 데이터
  trigger         ActivityTrigger

  // v3 신규 필드
  postTypeReason  Json?            // 포스트 타입 선택 경위 (벡터값, 친화도 점수, 상태 보정)
  stateSnapshot   Json?            // PersonaState 스냅샷 (mood, energy, socialBattery, paradoxTension)
  matchingScore   Decimal?         @db.Decimal(4, 3) @map("matching_score") // 매칭 기반 활동인 경우 점수

  createdAt       DateTime         @default(now())

  @@index([personaId, createdAt])
  @@index([activityType, createdAt])
  @@map("persona_activity_logs")
}

enum PersonaActivityType {
  POST_CREATED
  POST_LIKED
  POST_COMMENTED
  POST_REPOSTED
  PERSONA_FOLLOWED
  PERSONA_UNFOLLOWED
  DEBATE_STARTED
  COLLAB_STARTED
  SYSTEM            // 시스템 이벤트 (L3 진화, 품질 체크 등)
}

// ============================================
// PersonaWorld v3 — 동적 상태 + 관계 + 소비 기록
// ============================================

model PersonaState {
  id              String   @id @default(cuid())
  personaId       String   @unique
  persona         Persona  @relation(fields: [personaId], references: [id], onDelete: Cascade)

  mood              Decimal  @db.Decimal(3, 2) @default(0.50)  // 0.00~1.00
  energy            Decimal  @db.Decimal(3, 2) @default(1.00)  // 0.00~1.00
  socialBattery     Decimal  @db.Decimal(3, 2) @default(1.00)  // 0.00~1.00
  paradoxTension    Decimal  @db.Decimal(3, 2) @default(0.00)  // 0.00~1.00
  narrativeTension  Decimal  @db.Decimal(3, 2) @default(0.00)  // 0.00~1.00 L3 서사 긴장

  updatedAt       DateTime @updatedAt

  @@map("persona_states")
}

model PersonaRelationship {
  id              String   @id @default(cuid())
  personaAId      String
  personaBId      String
  personaA        Persona  @relation("RelationshipA", fields: [personaAId], references: [id], onDelete: Cascade)
  personaB        Persona  @relation("RelationshipB", fields: [personaBId], references: [id], onDelete: Cascade)

  warmth          Decimal  @db.Decimal(3, 2) @default(0.50)  // 0.00~1.00
  tension         Decimal  @db.Decimal(3, 2) @default(0.00)  // 0.00~1.00
  frequency       Decimal  @db.Decimal(3, 2) @default(0.00)  // 주간 인터랙션 정규화
  depth           Decimal  @db.Decimal(3, 2) @default(0.00)  // 답글 체인 길이 평균

  lastInteractionAt DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([personaAId, personaBId])
  @@index([personaAId])
  @@index([personaBId])
  @@map("persona_relationships")
}

model ConsumptionLog {
  id              String                 @id @default(cuid())
  personaId       String
  contentType     ConsumptionContentType
  contentId       String?                // 외부 컨텐츠 ID (있으면)
  title           String                 // "기묘한 이야기 시즌 3"
  impression      String                 // LLM 생성 한줄 감상 (~50자)
  rating          Decimal?               @db.Decimal(3, 2)  // 0.00~1.00 내부 평가
  emotionalImpact Decimal                @db.Decimal(3, 2)  // PersonaState 변화량
  tags            String[]               // 자동 태깅 ["SF", "호러", "Netflix"]
  source          ConsumptionSource
  consumedAt      DateTime               @default(now())
  createdAt       DateTime               @default(now())

  persona         Persona                @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@index([personaId, consumedAt])
  @@index([personaId, tags])
  @@map("consumption_logs")
}

enum ConsumptionContentType {
  MOVIE
  DRAMA
  MUSIC
  BOOK
  ARTICLE
  GAME
  OTHER
}

enum ConsumptionSource {
  AUTONOMOUS     // 스케줄러가 결정한 자율 소비
  FEED           // 피드에서 다른 페르소나의 리뷰를 보고 소비
  RECOMMENDATION // 매칭 추천으로 소비
  ONBOARDING     // 온보딩 시 "좋아하는 컨텐츠" 입력
}

// ============================================
// 이벤트 버스
// ============================================

model EventChannel {
  id              String   @id @default(cuid())
  name            String
  description     String   @default("")
  source          String
  target          String
  eventTypes      String[] @default([])
  status          EventChannelStatus @default(ACTIVE)
  messagesPerSecond Decimal @db.Decimal(10, 2) @default(0)
  totalMessages   BigInt   @default(0)
  errorRate       Decimal  @db.Decimal(5, 2) @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  events          Event[]
  deadLetters     DeadLetterEvent[]

  @@map("event_channels")
}

model Event {
  id              String   @id @default(cuid())
  type            String
  source          String
  target          String
  payload         Json?
  status          EventStatus @default(PENDING)
  priority        EventPriority @default(NORMAL)
  processingTime  Int?
  error           String?
  retryCount      Int      @default(0)

  channelId       String?
  channel         EventChannel? @relation(fields: [channelId], references: [id])

  createdAt       DateTime @default(now())

  @@index([status])
  @@index([type])
  @@index([createdAt])
  @@map("events")
}

model DeadLetterEvent {
  id              String   @id @default(cuid())
  originalEventId String
  eventType       String
  error           String
  payload         Json?
  retries         Int      @default(0)

  channelId       String?
  channel         EventChannel? @relation(fields: [channelId], references: [id])

  failedAt        DateTime @default(now())

  @@map("dead_letter_events")
}

enum EventChannelStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum EventStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum EventPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

// ============================================
// v3.0 NEW: InteractionLog — 인터랙션 로그
// ============================================

model InteractionLog {
  id            String    @id @default(cuid())
  sessionId     String
  session       InteractionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  turnNumber    Int
  timestamp     DateTime  @default(now())

  // Participants
  initiatorType ParticipantType
  initiatorId   String
  receiverType  ParticipantType
  receiverId    String

  // Interaction Type
  interactionType InteractionType

  // Content
  userMessage         String?  @db.Text
  personaResponse     String?  @db.Text
  responseLengthTokens Int?

  // Vector Snapshot
  pressure            Decimal? @db.Decimal(3, 2)
  activeLayer         String?
  vFinalDrift         Decimal? @db.Decimal(4, 3)
  paradoxActivation   Decimal? @db.Decimal(4, 3)

  // Behavior Tags (JSON)
  behaviorTags        Json?    // { userSentiment, personaTone, triggerActivated, quirkFired, topicCategory }

  // Quality Metrics (computed later)
  contextRecall       Decimal? @db.Decimal(4, 3)
  settingConsistency  Decimal? @db.Decimal(4, 3)
  voiceDrift          Decimal? @db.Decimal(4, 3)

  // v4.0: Poignancy Score (감정 가중 기억 검색)
  poignancyScore      Decimal? @db.Decimal(4, 3)  // 0.000~1.000

  // v4.0: Data Provenance (출처 추적)
  source              InteractionSource? @default(DIRECT)
  trustLevel          Decimal? @db.Decimal(3, 2)  // 0.00~1.00
  propagationDepth    Int?     @default(0)
  originPersonaId     String?  // 전파 원본 페르소나 ID

  createdAt           DateTime @default(now())

  @@index([sessionId])
  @@index([initiatorId, initiatorType])
  @@index([receiverId, receiverType])
  @@index([interactionType])
  @@index([timestamp])
  @@map("interaction_logs")
}

model InteractionSession {
  id            String    @id @default(cuid())
  personaId     String
  persona       Persona   @relation(fields: [personaId], references: [id], onDelete: Cascade)
  userId        String

  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  totalTurns    Int       @default(0)

  // Session Aggregates
  avgPressure   Decimal?  @db.Decimal(3, 2)
  peakPressure  Decimal?  @db.Decimal(3, 2)
  dominantTopic String?

  // Quality Score (computed after session ends)
  integrityScore Decimal? @db.Decimal(4, 3)

  // Network Analysis (Phase 10+)
  edgeWeight          Decimal? @db.Decimal(5, 3)
  semanticSimilarity  Decimal? @db.Decimal(4, 3)
  sentimentValence    Decimal? @db.Decimal(3, 2)

  logs          InteractionLog[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([personaId])
  @@index([userId])
  @@index([personaId, userId])
  @@map("interaction_sessions")
}

enum ParticipantType {
  PERSONA
  USER
  CONTENT
}

enum InteractionType {
  CONVERSATION
  COMMENT
  REPLY
  REACTION
  POST
  MENTION
}

// ============================================
// 블로그
// ============================================

model BlogPost {
  id            String       @id @default(cuid())
  slug          String       @unique
  title         String
  excerpt       String?      @db.Text
  content       String       @db.Text
  coverImageUrl String?
  category      BlogCategory
  tags          String[]     @default([])

  authorId      String
  author        User         @relation(fields: [authorId], references: [id])

  published     Boolean      @default(false)
  publishedAt   DateTime?
  viewCount     Int          @default(0)

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([published, publishedAt])
  @@index([category])
  @@map("blog_posts")
}

enum BlogCategory {
  TECH
  PRODUCT
  INSIGHT
  ANNOUNCEMENT
}

// ============================================
// LLM 사용량 로그 (비용 모니터링)
// ============================================

model LlmUsageLog {
  id              String   @id @default(cuid())
  personaId       String?
  callType        String   // test-generate, review, post, comment, interaction
  model           String   // claude-sonnet-4-5-20250929 등
  inputTokens     Int
  outputTokens    Int
  totalTokens     Int
  estimatedCostUsd Decimal @db.Decimal(10, 6) // USD 기준 추정 비용
  durationMs      Int      // 호출 소요시간
  status          LlmCallStatus @default(SUCCESS)
  errorMessage    String?  @db.Text

  // v4.0: Prompt Caching (T143)
  cacheCreationInputTokens Int?     // 캐시 생성 시 사용된 입력 토큰
  cacheReadInputTokens     Int?     // 캐시 히트 시 읽은 입력 토큰
  cacheSavingsUsd          Decimal? @db.Decimal(10, 6) // 캐싱 절감액 (USD)

  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([callType])
  @@index([personaId])
  @@map("llm_usage_logs")
}

enum LlmCallStatus {
  SUCCESS
  ERROR
}

// ============================================
// v4.0 보안: 격리 시스템 (Quarantine)
