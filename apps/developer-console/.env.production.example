# ============================================
# DeepSight Developer Console - PRODUCTION Environment
# ============================================
# Vercel 배포 시 Vercel Dashboard > Settings > Environment Variables에서 설정

# --------------------------------------------
# Application URLs (Required)
# --------------------------------------------
NEXT_PUBLIC_APP_URL="https://console.deepsight.ai"
NEXT_PUBLIC_API_URL="https://engine.deepsight.ai/api"

# --------------------------------------------
# Engine Studio Connection (Required)
# --------------------------------------------
NEXT_PUBLIC_ENGINE_STUDIO_URL="https://engine.deepsight.ai"

# --------------------------------------------
# Authentication (Required)
# --------------------------------------------
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://console.deepsight.ai"

# --------------------------------------------
# Database (Optional - 별도 DB 사용시)
# --------------------------------------------
# DATABASE_URL="postgresql://..."

# --------------------------------------------
# Production Settings
# --------------------------------------------
NEXT_PUBLIC_USE_MOCK_DATA="false"
NODE_ENV="production"

# --------------------------------------------
# Analytics (Optional)
# --------------------------------------------
# NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
# NEXT_PUBLIC_POSTHOG_KEY="phc_xxx"

# --------------------------------------------
# Feature Flags
# --------------------------------------------
FEATURE_DEMO_MODE="false"
