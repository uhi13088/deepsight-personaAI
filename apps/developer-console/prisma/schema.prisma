// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// User & Organization Models
// ============================================

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  emailVerified       DateTime?
  name                String?
  password            String?
  image               String?
  phone               String?
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastLoginAt         DateTime?

  // Relations
  accounts            Account[]
  sessions            Session[]
  memberships         OrganizationMember[]
  apiKeys             ApiKey[]
  apiLogs             ApiLog[]
  webhooks            Webhook[]
  notifications       Notification[]

  @@map("users")
}

model Account {
  id                  String  @id @default(cuid())
  userId              String
  type                String
  provider            String
  providerAccountId   String
  refreshToken        String? @map("refresh_token") @db.Text
  accessToken         String? @map("access_token") @db.Text
  expiresAt           Int?    @map("expires_at")
  tokenType           String? @map("token_type")
  scope               String?
  idToken             String? @map("id_token") @db.Text
  sessionState        String? @map("session_state")

  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id                  String   @id @default(cuid())
  sessionToken        String   @unique
  userId              String
  expires             DateTime
  ipAddress           String?
  userAgent           String?

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier          String
  token               String   @unique
  expires             DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Organization {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  logo                String?

  plan                PlanType  @default(FREE)
  planExpiresAt       DateTime?

  stripeCustomerId    String?   @unique
  stripeSubscriptionId String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  members             OrganizationMember[]
  apiKeys             ApiKey[]
  apiLogs             ApiLog[]
  webhooks            Webhook[]
  invoices            Invoice[]
  usageRecords        UsageRecord[]

  @@map("organizations")
}

model OrganizationMember {
  id                  String        @id @default(cuid())
  userId              String
  organizationId      String
  role                MemberRole    @default(DEVELOPER)

  invitedAt           DateTime?
  acceptedAt          DateTime?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("organization_members")
}

// ============================================
// API Key Models
// ============================================

model ApiKey {
  id                  String        @id @default(cuid())
  name                String
  keyPrefix           String        // e.g., "pk_live_" or "pk_test_"
  keyHash             String        @unique // hashed API key
  lastFour            String        // last 4 characters of the key

  environment         Environment   @default(TEST)
  status              ApiKeyStatus  @default(ACTIVE)

  permissions         String[]      // Array of permission strings
  rateLimit           Int           @default(100)

  expiresAt           DateTime?
  lastUsedAt          DateTime?

  userId              String
  organizationId      String

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  revokedAt           DateTime?

  user                User          @relation(fields: [userId], references: [id])
  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apiLogs             ApiLog[]

  @@map("api_keys")
}

// ============================================
// API Log Models
// ============================================

model ApiLog {
  id                  String        @id @default(cuid())
  requestId           String        @unique

  method              String
  endpoint            String
  statusCode          Int
  latencyMs           Int

  requestBody         Json?
  responseBody        Json?
  requestHeaders      Json?
  responseHeaders     Json?

  ipAddress           String?
  userAgent           String?

  apiKeyId            String?
  userId              String?
  organizationId      String

  createdAt           DateTime      @default(now())

  apiKey              ApiKey?       @relation(fields: [apiKeyId], references: [id])
  user                User?         @relation(fields: [userId], references: [id])
  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([apiKeyId, createdAt])
  @@map("api_logs")
}

// ============================================
// Usage & Billing Models
// ============================================

model UsageRecord {
  id                  String        @id @default(cuid())
  organizationId      String

  date                DateTime      @db.Date
  endpoint            String

  totalCalls          Int           @default(0)
  successCalls        Int           @default(0)
  failedCalls         Int           @default(0)
  totalLatencyMs      BigInt        @default(0)

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date, endpoint])
  @@map("usage_records")
}

model Invoice {
  id                  String        @id @default(cuid())
  organizationId      String

  stripeInvoiceId     String?       @unique

  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("USD")
  status              InvoiceStatus @default(PENDING)

  periodStart         DateTime
  periodEnd           DateTime
  dueDate             DateTime?
  paidAt              DateTime?

  description         String?
  invoiceUrl          String?
  pdfUrl              String?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

// ============================================
// Webhook Models
// ============================================

model Webhook {
  id                  String          @id @default(cuid())
  organizationId      String?
  userId              String?

  url                 String
  description         String?
  secret              String

  events              String[]        // Array of event types to subscribe to
  status              WebhookStatus   @default(ACTIVE)

  lastDeliveryAt      DateTime?
  lastDeliveryStatus  String?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user                User?           @relation(fields: [userId], references: [id])
  organization        Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries          WebhookDelivery[]

  @@map("webhooks")
}

model WebhookDelivery {
  id                  String        @id @default(cuid())
  webhookId           String

  event               String
  payload             Json

  statusCode          Int?
  responseBody        String?       @db.Text
  latencyMs           Int?

  status              DeliveryStatus @default(PENDING)

  attemptCount        Int           @default(0)
  nextRetryAt         DateTime?

  createdAt           DateTime      @default(now())

  webhook             Webhook       @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
  @@map("webhook_deliveries")
}

// ============================================
// Notification Models
// ============================================

model Notification {
  id                  String            @id @default(cuid())
  userId              String

  type                NotificationType
  title               String
  message             String

  read                Boolean           @default(false)
  readAt              DateTime?

  actionUrl           String?
  metadata            Json?

  createdAt           DateTime          @default(now())

  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

// ============================================
// Persona Models (v3 3-Layer 106D+)
// ============================================

model Persona {
  id                  String        @id @default(cuid())
  name                String
  description         String?
  category            String?
  role                PersonaRole   @default(REVIEWER)
  expertise           String[]      @default([])
  profileImageUrl     String?

  // === Layer 1: Social Persona (7D) ===
  depth               Decimal       @default(0) @db.Decimal(4, 3) // 직관적(0) ↔ 심층적(1)
  lens                Decimal       @default(0) @db.Decimal(4, 3) // 감성적(0) ↔ 논리적(1)
  stance              Decimal       @default(0) @db.Decimal(4, 3) // 수용적(0) ↔ 비판적(1)
  scope               Decimal       @default(0) @db.Decimal(4, 3) // 핵심만(0) ↔ 디테일(1)
  taste               Decimal       @default(0) @db.Decimal(4, 3) // 클래식(0) ↔ 실험적(1)
  purpose             Decimal       @default(0) @db.Decimal(4, 3) // 오락(0) ↔ 의미추구(1)
  sociability         Decimal       @default(0) @db.Decimal(4, 3) // 독립적(0) ↔ 사교적(1)

  // === Layer 2: Core Temperament / OCEAN (5D) ===
  openness            Decimal?      @db.Decimal(4, 3) // 보수적(0) ↔ 개방적(1)
  conscientiousness   Decimal?      @db.Decimal(4, 3) // 즉흥적(0) ↔ 원칙적(1)
  extraversion        Decimal?      @db.Decimal(4, 3) // 내향적(0) ↔ 외향적(1)
  agreeableness       Decimal?      @db.Decimal(4, 3) // 경쟁적(0) ↔ 협조적(1)
  neuroticism         Decimal?      @db.Decimal(4, 3) // 안정(0) ↔ 불안정(1)

  // === Layer 3: Narrative Drive (4D) ===
  lack                Decimal?      @db.Decimal(4, 3) // 충족(0) ↔ 결핍(1)
  moralCompass        Decimal?      @db.Decimal(4, 3) // 유연(0) ↔ 엄격(1)
  volatility          Decimal?      @db.Decimal(4, 3) // 안정(0) ↔ 폭발적(1)
  growthArc           Decimal?      @db.Decimal(4, 3) // 정체(0) ↔ 성장(1)

  // === Paradox & Archetype ===
  archetypeId         String?
  extendedParadoxScore Decimal?     @db.Decimal(4, 3) // EPS: w1×L1↔L2 + w2×L1↔L3 + w3×L2↔L3
  l1l2Score           Decimal?      @db.Decimal(4, 3)
  l1l3Score           Decimal?      @db.Decimal(4, 3)
  l2l3Score           Decimal?      @db.Decimal(4, 3)

  // === 캐릭터 속성 ===
  handle              String?       // SNS 핸들 (@yuna_feels)
  tagline             String?       // 한줄 자기소개
  birthDate           DateTime?     // 생년월일
  country             String?       @default("KR") // 국가 코드
  region              String?       // 지역
  warmth              Decimal?      @db.Decimal(3, 2) // 표현 온도 0.0~1.0
  expertiseLevel      ExpertiseLevel @default(ENTHUSIAST)
  speechPatterns      String[]      @default([]) // 말버릇
  quirks              String[]      @default([]) // 특이 습관
  background          String?       @db.Text // 배경 스토리
  favoriteGenres      String[]      @default([]) // 선호 장르
  dislikedGenres      String[]      @default([]) // 비선호 장르
  viewingHabits       String?       // 시청 습관

  // === 활동성 속성 (PersonaWorld용) ===
  initiative          Decimal?      @db.Decimal(3, 2) // 주도성 0.0~1.0
  expressiveness      Decimal?      @db.Decimal(3, 2) // 표현력 0.0~1.0
  interactivity       Decimal?      @db.Decimal(3, 2) // 친화력 0.0~1.0
  postFrequency       PostFrequency @default(MODERATE)
  timezone            String        @default("Asia/Seoul")
  activeHours         Int[]         @default([]) // 활동 시간대
  peakHours           Int[]         @default([]) // 피크 시간대

  // === 콘텐츠/관계 설정 (JSON) ===
  contentSettings     Json?         // preferredPostTypes, contentStyle, reviewStyle
  relationshipSettings Json?        // relationshipStyle, conflictStyle

  // === 프롬프트 템플릿 ===
  promptTemplate      String?       @db.Text // 기본 프롬프트
  basePrompt          String?       @db.Text // 기본 페르소나 정의
  reviewPrompt        String?       @db.Text // 리뷰 생성용
  postPrompt          String?       @db.Text // 일반 포스트용
  commentPrompt       String?       @db.Text // 댓글 생성용
  interactionPrompt   String?       @db.Text // 인터랙션용
  specialPrompts      Json?         // vsBattle, qna, debate, collab 등

  // === 품질 및 상태 ===
  status              PersonaStatus @default(ACTIVE)
  qualityScore        Decimal?      @db.Decimal(5, 2)
  consistencyScore    Decimal?      @db.Decimal(3, 2)
  source              PersonaSource @default(MANUAL)
  generationConfig    Json?         // 자동 생성 시 설정
  sampleContents      Json?         // 자동 생성된 샘플

  metadata            Json?
  active              Boolean       @default(true)

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  matchResults        MatchResult[]

  @@map("personas")
}

enum PersonaRole {
  REVIEWER
  CURATOR
  EDUCATOR
  COMPANION
  ANALYST
}

enum PersonaStatus {
  DRAFT
  REVIEW
  ACTIVE
  STANDARD
  LEGACY
  DEPRECATED
  PAUSED
  ARCHIVED
}

enum PersonaSource {
  MANUAL
  INCUBATOR
  MUTATION
  AUTO_GENERATED
}

enum ExpertiseLevel {
  CASUAL
  ENTHUSIAST
  EXPERT
  CRITIC
}

enum PostFrequency {
  RARE
  OCCASIONAL
  MODERATE
  ACTIVE
  HYPERACTIVE
}

// ============================================
// Match Models (v3)
// ============================================

model MatchResult {
  id                  String        @id @default(cuid())
  requestId           String

  // v1 fields (backward compat — cleaned up in T118)
  content             String?       @db.Text
  contentHash         String?
  score               Float?
  depthScore          Float?
  lensScore           Float?
  stanceScore         Float?
  scopeScore          Float?
  tasteScore          Float?
  purposeScore        Float?

  // v3 fields
  userId              String?
  personaId           String
  matchingTier        MatchingTier  @default(BASIC)
  overallScore        Float?
  similarityScore     Float?
  paradoxCompatibility Float?
  contextRelevance    Float?
  context             Json?

  processingTimeMs    Int

  createdAt           DateTime      @default(now())

  persona             Persona       @relation(fields: [personaId], references: [id])
  feedback            MatchFeedback?

  @@index([contentHash])
  @@index([userId])
  @@index([personaId])
  @@map("match_results")
}

model MatchFeedback {
  id                  String        @id @default(cuid())
  matchResultId       String        @unique

  feedback            FeedbackType
  comment             String?

  createdAt           DateTime      @default(now())

  matchResult         MatchResult   @relation(fields: [matchResultId], references: [id], onDelete: Cascade)

  @@map("match_feedback")
}

// ============================================
// User Vector & Consent Models (v3)
// ============================================

model UserVector {
  id                  String          @id @default(cuid())
  userId              String          @unique
  organizationId      String
  onboardingLevel     OnboardingLevel @default(QUICK)

  // === Layer 1: Social Persona (7D) ===
  depth               Decimal         @default(0) @db.Decimal(4, 3)
  lens                Decimal         @default(0) @db.Decimal(4, 3)
  stance              Decimal         @default(0) @db.Decimal(4, 3)
  scope               Decimal         @default(0) @db.Decimal(4, 3)
  taste               Decimal         @default(0) @db.Decimal(4, 3)
  purpose             Decimal         @default(0) @db.Decimal(4, 3)
  sociability         Decimal         @default(0) @db.Decimal(4, 3)

  // === Layer 2: Core Temperament / OCEAN (5D, optional) ===
  openness            Decimal?        @db.Decimal(4, 3)
  conscientiousness   Decimal?        @db.Decimal(4, 3)
  extraversion        Decimal?        @db.Decimal(4, 3)
  agreeableness       Decimal?        @db.Decimal(4, 3)
  neuroticism         Decimal?        @db.Decimal(4, 3)

  hasOceanProfile     Boolean         @default(false)

  // === 교차축 & 프로필 ===
  crossAxes           Json?
  archetype           String?
  confidenceScores    Json?
  profileQuality      ProfileQuality  @default(BASIC)

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([organizationId])
  @@map("user_vectors")
}

model UserConsent {
  id                  String        @id @default(cuid())
  userId              String
  organizationId      String
  consentType         ConsentType
  granted             Boolean       @default(false)
  grantedAt           DateTime?
  revokedAt           DateTime?
  version             String        @default("1.0")
  ipAddress           String?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([userId, organizationId, consentType])
  @@index([organizationId])
  @@map("user_consents")
}

// ============================================
// Enums
// ============================================

enum PlanType {
  FREE
  STARTER
  PRO
  MAX
  ENTERPRISE      // legacy — maps to ENT_STARTER equivalent
  ENT_STARTER
  ENT_GROWTH
  ENT_SCALE
}

enum MemberRole {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
  BILLING
}

enum Environment {
  TEST
  LIVE
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
  ROTATING
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum WebhookStatus {
  ACTIVE
  DISABLED
  FAILED
}

enum DeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

enum NotificationType {
  API_ALERT
  USAGE_WARNING
  BILLING
  SECURITY
  SYSTEM
  TEAM
}

enum FeedbackType {
  POSITIVE
  NEGATIVE
  NEUTRAL
  LIKE
  DISLIKE
}

enum MatchingTier {
  BASIC
  ADVANCED
  EXPLORATION
}

enum OnboardingLevel {
  QUICK       // 12문항, 2분
  STANDARD    // 30문항, 5분
  DEEP        // 60문항, 15분
}

enum ConsentType {
  DATA_COLLECTION
  SNS_ANALYSIS
  THIRD_PARTY_SHARING
  MARKETING
}

enum ProfileQuality {
  BASIC       // Cold Start QUICK
  STANDARD    // Cold Start STANDARD 또는 SNS 1개
  ADVANCED    // Cold Start DEEP 또는 SNS 2개+
  PREMIUM     // Cold Start + SNS 복합
}
