// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// User & Organization Models
// ============================================

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  emailVerified       DateTime?
  name                String?
  password            String?
  image               String?
  phone               String?
  twoFactorEnabled    Boolean   @default(false)
  twoFactorSecret     String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  lastLoginAt         DateTime?

  // Relations
  accounts            Account[]
  sessions            Session[]
  memberships         OrganizationMember[]
  apiKeys             ApiKey[]
  apiLogs             ApiLog[]
  webhooks            Webhook[]
  notifications       Notification[]

  @@map("users")
}

model Account {
  id                  String  @id @default(cuid())
  userId              String
  type                String
  provider            String
  providerAccountId   String
  refresh_token       String? @db.Text
  access_token        String? @db.Text
  expires_at          Int?
  token_type          String?
  scope               String?
  id_token            String? @db.Text
  session_state       String?

  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id                  String   @id @default(cuid())
  sessionToken        String   @unique
  userId              String
  expires             DateTime
  ipAddress           String?
  userAgent           String?

  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier          String
  token               String   @unique
  expires             DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Organization {
  id                  String    @id @default(cuid())
  name                String
  slug                String    @unique
  logo                String?

  plan                PlanType  @default(FREE)
  planExpiresAt       DateTime?

  stripeCustomerId    String?   @unique
  stripeSubscriptionId String?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  members             OrganizationMember[]
  apiKeys             ApiKey[]
  apiLogs             ApiLog[]
  webhooks            Webhook[]
  invoices            Invoice[]
  usageRecords        UsageRecord[]

  @@map("organizations")
}

model OrganizationMember {
  id                  String        @id @default(cuid())
  userId              String
  organizationId      String
  role                MemberRole    @default(DEVELOPER)

  invitedAt           DateTime?
  acceptedAt          DateTime?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("organization_members")
}

// ============================================
// API Key Models
// ============================================

model ApiKey {
  id                  String        @id @default(cuid())
  name                String
  keyPrefix           String        // e.g., "pk_live_" or "pk_test_"
  keyHash             String        @unique // hashed API key
  lastFour            String        // last 4 characters of the key

  environment         Environment   @default(TEST)
  status              ApiKeyStatus  @default(ACTIVE)

  permissions         String[]      // Array of permission strings
  rateLimit           Int           @default(100)

  expiresAt           DateTime?
  lastUsedAt          DateTime?

  userId              String
  organizationId      String

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  revokedAt           DateTime?

  user                User          @relation(fields: [userId], references: [id])
  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  apiLogs             ApiLog[]

  @@map("api_keys")
}

// ============================================
// API Log Models
// ============================================

model ApiLog {
  id                  String        @id @default(cuid())
  requestId           String        @unique

  method              String
  endpoint            String
  statusCode          Int
  latencyMs           Int

  requestBody         Json?
  responseBody        Json?
  requestHeaders      Json?
  responseHeaders     Json?

  ipAddress           String?
  userAgent           String?

  apiKeyId            String?
  userId              String?
  organizationId      String

  createdAt           DateTime      @default(now())

  apiKey              ApiKey?       @relation(fields: [apiKeyId], references: [id])
  user                User?         @relation(fields: [userId], references: [id])
  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
  @@index([apiKeyId, createdAt])
  @@map("api_logs")
}

// ============================================
// Usage & Billing Models
// ============================================

model UsageRecord {
  id                  String        @id @default(cuid())
  organizationId      String

  date                DateTime      @db.Date
  endpoint            String

  totalCalls          Int           @default(0)
  successCalls        Int           @default(0)
  failedCalls         Int           @default(0)
  totalLatencyMs      BigInt        @default(0)

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, date, endpoint])
  @@map("usage_records")
}

model Invoice {
  id                  String        @id @default(cuid())
  organizationId      String

  stripeInvoiceId     String?       @unique

  amount              Decimal       @db.Decimal(10, 2)
  currency            String        @default("USD")
  status              InvoiceStatus @default(PENDING)

  periodStart         DateTime
  periodEnd           DateTime
  dueDate             DateTime?
  paidAt              DateTime?

  description         String?
  invoiceUrl          String?
  pdfUrl              String?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  organization        Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

// ============================================
// Webhook Models
// ============================================

model Webhook {
  id                  String          @id @default(cuid())
  organizationId      String?
  userId              String?

  url                 String
  description         String?
  secret              String

  events              String[]        // Array of event types to subscribe to
  status              WebhookStatus   @default(ACTIVE)

  lastDeliveryAt      DateTime?
  lastDeliveryStatus  String?

  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  user                User?           @relation(fields: [userId], references: [id])
  organization        Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deliveries          WebhookDelivery[]

  @@map("webhooks")
}

model WebhookDelivery {
  id                  String        @id @default(cuid())
  webhookId           String

  event               String
  payload             Json

  statusCode          Int?
  responseBody        String?       @db.Text
  latencyMs           Int?

  status              DeliveryStatus @default(PENDING)

  attemptCount        Int           @default(0)
  nextRetryAt         DateTime?

  createdAt           DateTime      @default(now())

  webhook             Webhook       @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId, createdAt])
  @@map("webhook_deliveries")
}

// ============================================
// Notification Models
// ============================================

model Notification {
  id                  String            @id @default(cuid())
  userId              String

  type                NotificationType
  title               String
  message             String

  read                Boolean           @default(false)
  readAt              DateTime?

  actionUrl           String?
  metadata            Json?

  createdAt           DateTime          @default(now())

  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

// ============================================
// Persona Models (Core AI Feature)
// ============================================

model Persona {
  id                  String        @id @default(cuid())
  name                String
  description         String?
  category            String?

  // 6D Vector dimensions (stored as Float for vector operations)
  depth               Float         @default(0)
  lens                Float         @default(0)
  stance              Float         @default(0)
  scope               Float         @default(0)
  taste               Float         @default(0)
  purpose             Float         @default(0)

  metadata            Json?

  active              Boolean       @default(true)

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  matchResults        MatchResult[]

  @@map("personas")
}

model MatchResult {
  id                  String        @id @default(cuid())
  requestId           String

  content             String        @db.Text
  contentHash         String        // For caching

  personaId           String
  score               Float

  // Individual dimension scores
  depthScore          Float?
  lensScore           Float?
  stanceScore         Float?
  scopeScore          Float?
  tasteScore          Float?
  purposeScore        Float?

  processingTimeMs    Int

  createdAt           DateTime      @default(now())

  persona             Persona       @relation(fields: [personaId], references: [id])
  feedback            MatchFeedback?

  @@index([contentHash])
  @@map("match_results")
}

model MatchFeedback {
  id                  String        @id @default(cuid())
  matchResultId       String        @unique

  feedback            FeedbackType
  comment             String?

  createdAt           DateTime      @default(now())

  matchResult         MatchResult   @relation(fields: [matchResultId], references: [id], onDelete: Cascade)

  @@map("match_feedback")
}

// ============================================
// Enums
// ============================================

enum PlanType {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum MemberRole {
  OWNER
  ADMIN
  DEVELOPER
  VIEWER
  BILLING
}

enum Environment {
  TEST
  LIVE
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
  EXPIRED
  ROTATING
}

enum InvoiceStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum WebhookStatus {
  ACTIVE
  DISABLED
  FAILED
}

enum DeliveryStatus {
  PENDING
  SUCCESS
  FAILED
  RETRYING
}

enum NotificationType {
  API_ALERT
  USAGE_WARNING
  BILLING
  SECURITY
  SYSTEM
  TEAM
}

enum FeedbackType {
  POSITIVE
  NEGATIVE
  NEUTRAL
}
