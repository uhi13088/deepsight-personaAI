{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Bash(rm -rf:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(sudo:*)"
    ],
    "ask": ["Bash(git push --force:*)", "Bash(pnpm publish:*)", "Bash(pnpm run deploy:*)"],
    "allow": [
      "Read(./**)",
      "Write(./**)",
      "Edit(./**)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git checkout:*)",
      "Bash(git fetch:*)",
      "Bash(git push:*)",
      "Bash(pnpm:*)",
      "Bash(npx:*)",
      "Bash(tsc:*)",
      "Bash(eslint:*)",
      "Bash(prettier:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/format-changed-file.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./hooks/output-secret-filter.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'if printf \"%s\" \"$TOOL_INPUT\" | grep -qE \"git commit\"; then if [ -f tasks/lessons.md ] && ! grep -q \"^- \\[\" tasks/lessons.md 2>/dev/null; then echo \"[reminder] tasks/lessons.md is empty. Record learnings before committing.\" >> /tmp/claude-reminders.log 2>&1; fi; fi; exit 0'"
          },
          {
            "type": "command",
            "command": "bash ./hooks/db-guard.sh",
            "timeout": 2000
          }
        ]
      }
    ]
  }
}
