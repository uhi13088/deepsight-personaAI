{
  "name": "@deepsight/sdk",
  "version": "0.1.0",
  "description": "DeepSight API SDK for JavaScript/TypeScript",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "deepsight",
    "persona",
    "ai",
    "matching",
    "sdk"
  ],
  "author": "DeepSight",
  "license": "MIT",
  "dependencies": {
    "@deepsight/shared-types": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "typescript": ">=4.7"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  }
}
